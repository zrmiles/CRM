# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mini_crm

# Security
SECRET_KEY=your-super-secret-key-min-32-chars-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_RATE_LIMIT_PER_MINUTE=60
REDIS_URL=redis://localhost:6379/0
REFRESH_TOKEN_COOKIE_NAME=mini_crm_refresh_token
REFRESH_TOKEN_COOKIE_SECURE=false

# Application
APP_NAME=Mini-CRM
DEBUG=false

# CORS (разделяйте запятой для нескольких origins)
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:8080"]
